# --- Terraform (based on HashiCorp's canonical .gitignore) ---

# Local .terraform directories (provider/module cache)
**/.terraform/*

# State files — may contain secrets
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files — may contain credentials. Keep the committed examples.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Saved plan files (can contain sensitive values)
*.tfplan
tfplan

# Override files — usually local-only customizations
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# NOTE: .terraform.lock.hcl is intentionally NOT ignored — commit it so provider
# versions are pinned for everyone.

# --- Project-specific secrets (out-of-band Teleport artifacts) ---
# identity: Teleport provider identity file from `tctl auth sign`
identity
# *.pem: CA bundles / certs (e.g. teleport-awsra-ca.pem); *.key: private keys
*.pem
*.key

# Local AWS credentials file for tests (static keys) — never commit
**/.aws-credentials

# --- Terragrunt ---
# Materialized stack units (regenerated by `terragrunt stack generate`)
**/.terragrunt-stack/
# Terragrunt's local cache + rendered config dumps
.terragrunt-cache/
**/terragrunt.rendered.json
# NOTE: live/<env>/terragrunt.stack.hcl IS committed — it's the generated, but
# reviewable, output of live/scripts/generate-stacks.py from inventory.yaml.

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
